{
  "name": "akm CLI",
  "description": "Search, show, and manage akm stash assets from local directories and registries.",
  "version": "0.2.0",
  "author": {
    "name": "itlackey",
    "url": "https://github.com/itlackey"
  },
  "homepage": "https://github.com/itlackey/akm-plugins#readme",
  "repository": "https://github.com/itlackey/akm-plugins",
  "license": "MPL-2.0",
  "keywords": [
    "akm",
    "agentikit",
    "stash",
    "skills",
    "commands",
    "agents",
    "scripts",
    "registry",
    "plugin"
  ],
  "skills": [
    "./skills/agentikit"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/agentikit-hook.sh\" ensure-akm",
            "timeout": 120,
            "statusMessage": "Ensuring the latest AKM CLI is available..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/agentikit-hook.sh\" user-feedback",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/agentikit-hook.sh\" post-tool success",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/agentikit-hook.sh\" post-tool failure",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
